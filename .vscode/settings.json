        "/^node -e \"\n// Reproduce the autotile logic to see actual values\nconst S = -99, _ = -1;\n\n// 6x6 2-thick box\nconst tiles = \\[\n  \\[S,S,S,S,S,S\\],\n  \\[S,S,S,S,S,S\\],\n  \\[S,S,_,_,S,S\\],\n  \\[S,S,_,_,S,S\\],\n  \\[S,S,S,S,S,S\\],\n  \\[S,S,S,S,S,S\\],\n\\];\n\nconst TEST_SET = \\{\n  topLeft:10, top:11, topRight:12,\n  left:20, center:21, right:22,\n  bottomLeft:30, bottom:31, bottomRight:32,\n\\};\n\nconst h=tiles\\.length, w=tiles\\[0\\]\\.length;\nconst snap = tiles\\.map\\(r=>\\[\\.\\.\\.r\\]\\);\nconst isSolid = \\(r,c\\) => \\(r<0\\|\\|r>=h\\|\\|c<0\\|\\|c>=w\\) \\? true : snap\\[r\\]\\[c\\]===S;\n\nfunction pick\\(u,d,l,r,s\\) \\{\n  const v = !u\\?'top':!d\\?'bottom':'middle';\n  const hz = !l\\?'left':!r\\?'right':'center';\n  if\\(v==='top'&&hz==='left'\\) return s\\.topLeft;\n  if\\(v==='top'&&hz==='center'\\) return s\\.top;\n  if\\(v==='top'&&hz==='right'\\) return s\\.topRight;\n  if\\(v==='middle'&&hz==='left'\\) return s\\.left;\n  if\\(v==='middle'&&hz==='center'\\) return s\\.center;\n  if\\(v==='middle'&&hz==='right'\\) return s\\.right;\n  if\\(v==='bottom'&&hz==='left'\\) return s\\.bottomLeft;\n  if\\(v==='bottom'&&hz==='center'\\) return s\\.bottom;\n  return s\\.bottomRight;\n\\}\n\nfor\\(let r=0;r<h;r\\+\\+\\)\\{\n  for\\(let c=0;c<w;c\\+\\+\\)\\{\n    if\\(snap\\[r\\]\\[c\\]!==S\\) continue;\n    tiles\\[r\\]\\[c\\]=pick\\(isSolid\\(r-1,c\\),isSolid\\(r\\+1,c\\),isSolid\\(r,c-1\\),isSolid\\(r,c\\+1\\),TEST_SET\\);\n  \\}\n\\}\n\nconsole\\.log\\('2-thick box result:'\\);\ntiles\\.forEach\\(\\(row,i\\)=>console\\.log\\(i\\+': '\\+JSON\\.stringify\\(row\\)\\)\\);\n\n// Also do the 1-thick SIMPLE_ROOM corners/edges\nconst room = \\[\n  Array\\(20\\)\\.fill\\(S\\),\n  \\.\\.\\.\\(Array\\(13\\)\\.fill\\(null\\)\\.map\\(\\(\\)=>\\{const r=Array\\(20\\)\\.fill\\(_\\);r\\[0\\]=S;r\\[19\\]=S;return r;\\}\\)\\),\n  Array\\(20\\)\\.fill\\(S\\),\n\\];\nconst rh=room\\.length, rw=room\\[0\\]\\.length;\nconst rsnap=room\\.map\\(r=>\\[\\.\\.\\.r\\]\\);\nconst rSolid=\\(r,c\\)=>\\(r<0\\|\\|r>=rh\\|\\|c<0\\|\\|c>=rw\\)\\?true:rsnap\\[r\\]\\[c\\]===S;\nfor\\(let r=0;r<rh;r\\+\\+\\)\\{\n  for\\(let c=0;c<rw;c\\+\\+\\)\\{\n    if\\(rsnap\\[r\\]\\[c\\]!==S\\) continue;\n    room\\[r\\]\\[c\\]=pick\\(rSolid\\(r-1,c\\),rSolid\\(r\\+1,c\\),rSolid\\(r,c-1\\),rSolid\\(r,c\\+1\\),TEST_SET\\);\n  \\}\n\\}\nconsole\\.log\\('\\\\n1-thick room key positions:'\\);\nconsole\\.log\\('\\(0,0\\)='\\+room\\[0\\]\\[0\\], '\\(0,5\\)='\\+room\\[0\\]\\[5\\], '\\(0,19\\)='\\+room\\[0\\]\\[19\\]\\);\nconsole\\.log\\('\\(5,0\\)='\\+room\\[5\\]\\[0\\], '\\(5,19\\)='\\+room\\[5\\]\\[19\\]\\);\nconsole\\.log\\('\\(14,0\\)='\\+room\\[14\\]\\[0\\], '\\(14,5\\)='\\+room\\[14\\]\\[5\\], '\\(14,19\\)='\\+room\\[14\\]\\[19\\]\\);\n\"\n$/": {
